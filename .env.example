# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# For dorpts project, use https://dorpts.web.app (Firebase Hosting)
# or https://dorpts.pages.dev (Cloudflare Pages).
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://dorpts.web.app"

# FIREBASE_SERVICE_ACCOUNT: Paste the JSON service account from
# Firebase Console > Project Settings > Service Accounts (dorpts project).
FIREBASE_SERVICE_ACCOUNT

# RESEND_API_KEY: Required for sending OTP emails via Resend.
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_..."
